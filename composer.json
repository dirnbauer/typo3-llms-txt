{
    "name": "webconsulting/typo3-llms-txt",
    "type": "typo3-cms-extension",
    "description": "Serves /llms.txt and /agents.md per TYPO3 site, generated from the page tree and site configuration — deliberate publishing for the agent-readable web.",
    "license": "GPL-2.0-or-later",
    "keywords": [
        "typo3",
        "llms.txt",
        "agents.md",
        "ai",
        "agents",
        "aeo"
    ],
    "authors": [
        {
            "name": "Kurt Dirnbauer",
            "email": "dirnbauer@webconsulting.at",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.3",
        "typo3/cms-core": "^14.3",
        "symfony/console": "^7.0"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^11.0",
        "webconsulting/typo3-abilities": "@dev"
    },
    "suggest": {
        "hn/typo3-mcp-server": "agents.md advertises the MCP endpoint when installed",
        "webconsulting/typo3-abilities": "agents.md lists the registered abilities when installed"
    },
    "autoload": {
        "psr-4": {
            "Webconsulting\\LlmsTxt\\": "Classes/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Webconsulting\\LlmsTxt\\Tests\\": "Tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "typo3/class-alias-loader": true,
            "typo3/cms-composer-installers": true
        },
        "sort-packages": true
    },
    "extra": {
        "typo3/cms": {
            "extension-key": "llms_txt"
        }
    },
    "scripts": {
        "phpstan": "php -d memory_limit=1G vendor/bin/phpstan analyse",
        "test": "phpunit"
    },
    "repositories": [
        {
            "type": "path",
            "url": "../abilities"
        }
    ]
}
